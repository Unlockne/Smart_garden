APP_NAME=smart-garden-api
APP_ENV=development
API_PREFIX=/api/v1

DATABASE_URL=

POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=smart_garden
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ADAFRUIT_IO_USERNAME=your_username
ADAFRUIT_IO_KEY=your_key
ADAFRUIT_FEED_KEY=smart-garden-sensors
ADAFRUIT_COMMAND_FEED_KEY=smart-garden-commands
ENABLE_ADAFRUIT_POLLING=false
INGESTION_POLL_SECONDS=5

ENABLE_AUTO_MODE=true
AUTO_SOIL_ON=30
AUTO_SOIL_OFF=40
AUTO_TEMP_ON=32
AUTO_TEMP_OFF=30
AUTO_LIGHT_ON=300
AUTO_LIGHT_OFF=400

CORS_ORIGINS=http://localhost:5173

# ML (Keras) — mặc định trỏ tới ml/models trong repo
ENABLE_ML_INFERENCE=true
# ML_MODEL_PATH=
# ML_LABELS_PATH=

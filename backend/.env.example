APP_NAME=smart-garden-api
APP_ENV=development
API_PREFIX=/api/v1

SQLITE_PATH=backend/app/data.db

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smart_garden
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

ADAFRUIT_IO_USERNAME=your_username
ADAFRUIT_IO_KEY=your_key

ADAFRUIT_MQTT_BROKER=io.adafruit.com
ADAFRUIT_MQTT_PORT=1883

# Sensor feeds (tên feed trên Adafruit IO)
ADAFRUIT_FEED_AIR_TEMPERATURE=air-temperature
ADAFRUIT_FEED_AIR_HUMIDITY=air-humidity
ADAFRUIT_FEED_SOIL_MOISTURE=soil-moisture
ADAFRUIT_FEED_LIGHT_LEVEL=light-level

# Control feeds (backend publish, device subscribe)
ADAFRUIT_FEED_PUMP_CONTROL=pump-control
ADAFRUIT_FEED_FAN_CONTROL=fan-control
ADAFRUIT_FEED_LIGHT_CONTROL=light-control

CORS_ORIGINS=http://localhost:5173
